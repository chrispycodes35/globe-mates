rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Groups collection - anyone authenticated can read, but only backend can write
    match /groups/{groupId} {
      // Allow authenticated users to read groups
      allow read: if request.auth != null;
      // Writing is handled by backend (Firebase Admin SDK)
      allow write: if false;
      
      // Group messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        // Authenticated users can send messages to groups they're members of
        allow create: if request.auth != null && 
                      exists(/databases/$(database)/documents/groups/$(groupId)) &&
                      request.auth.uid in resource.data.memberIds;
        allow update, delete: if request.auth != null && 
                             request.resource.data.userId == request.auth.uid;
      }
      
      // Group posts subcollection
      match /posts/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
                      exists(/databases/$(database)/documents/groups/$(groupId)) &&
                      request.auth.uid in resource.data.memberIds;
        allow update, delete: if request.auth != null && 
                             request.resource.data.userId == request.auth.uid;
      }
    }
  }
}

